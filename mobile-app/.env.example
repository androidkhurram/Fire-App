# Optional: only used if `admin-portal/.env.local` does not exist.
# When the admin env file is present, the app reads that file instead (same Supabase as the web dashboard).
# Restart Metro after changing values.

# Supabase: usually set only in admin-portal/.env.local (NEXT_PUBLIC_*). Leave these lines
# out of mobile-app/.env if you use admin env — empty placeholders used to wipe admin keys.
# For mobile-only setup, set URL + anon key here (or NEXT_PUBLIC_*); both work in config.ts.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Google Places (enable Places API on the key; restrict by app bundle ID in GCP)
# Address autocomplete (also ok in mobile-app/.env when using admin-portal/.env.local for Supabase)
GOOGLE_PLACES_API_KEY=
LOCATIONIQ_API_KEY=

# Optional fallback autocomplete (locationiq.com)
LOCATIONIQ_API_KEY=
