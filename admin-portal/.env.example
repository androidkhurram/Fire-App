# Copy to .env.local. All three Supabase lines below are required for the admin app to run locally.
# Supabase (required for auth and data)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for adding technicians from the dashboard
# Get from Supabase Dashboard → Settings → API → service_role (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Twilio SMS reminders (inspection due notifications)
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Cron job auth (Vercel sends this when invoking cron; set same value in Vercel env)
CRON_SECRET=your_random_secret_at_least_16_chars
